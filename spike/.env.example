# Copy to spike/.env (gitignored) and fill in. The spike probes read this.
# Nebius AI Studio is OpenAI-compatible.
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1
# Optional: pin a chat model id. If blank, nebius_probe.py lists /v1/models and picks one.
NEBIUS_MODEL=

# Optional this pass — only needed for the Pinecone probe (item 6).
PINECONE_API_KEY=
