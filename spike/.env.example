# Copy to spike/.env (gitignored) and fill in. The spike probes read this.
# All generation providers are OpenAI-compatible (base_url + key) — the same
# ModelProvider.generate() seam the app uses. Fill any you have; gen_probe.py
# probes each one that has a key.

# --- Nebius (the MANDATORY final provider; credit arrives later today/Mon) ---
NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
NEBIUS_MODEL=            # blank -> gen_probe.py auto-picks from /v1/models

# --- OpenRouter (best Nebius stand-in: OpenAI-compatible + open models) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct   # an OPEN model = representative of Nebius

# --- OpenAI (second provider for the pluggability/swap demo) ---
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Pinecone (Phase 2 only; not a Phase-0 gate) ---
PINECONE_API_KEY=
