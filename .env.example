# Copy to .env (gitignored). Generation providers are OpenAI-compatible (base_url + key + model)
# behind ModelProvider.generate(). Pick the active one with GENACADEMY_PROVIDER.
# Options: openrouter | openai | nebius | gemma. Dev default: openrouter.
GENACADEMY_PROVIDER=openrouter

NEBIUS_API_KEY=
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/
# Set when credit lands for the mandatory final call.
NEBIUS_MODEL=

# Phase 2 embedding preset: local (default, offline) or nebius (OpenAI-compatible).
# NEBIUS_API_KEY/NEBIUS_BASE_URL are reused for embeddings independently of GENACADEMY_PROVIDER.
# Same-embedder corpus rule: switching embedders requires re-ingesting a fresh collection.
# Dimension mismatch fails loudly by design at vector-store upsert/query time.
GENACADEMY_EMBEDDINGS=local
GENACADEMY_EMBED_MODEL=all-MiniLM-L6-v2
NEBIUS_EMBED_MODEL=Qwen/Qwen3-Embedding-8B
# Default 384 matches local all-MiniLM-L6-v2. For Qwen/Qwen3-Embedding-8B + Pinecone, use 4096.
GENACADEMY_EMBED_DIM=384

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.1-70b-instruct

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

GEMMA_BASE_URL=http://127.0.0.1:8085/v1
GEMMA_MODEL=gemma-3-12b-it

GENACADEMY_SESSION_SECRET=dev-only-change-me

# Optional Phase 2 cross-encoder rerank. Disabled by default to preserve Phase 0/1 behavior.
GENACADEMY_RERANK_ENABLED=false
GENACADEMY_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L6-v2
GENACADEMY_RERANK_LOCAL_FILES_ONLY=true
GENACADEMY_RERANK_BATCH_SIZE=32
GENACADEMY_RERANK_POOL=0
GENACADEMY_RERANK_DEVICE=
GENACADEMY_RERANK_CACHE_DIR=

# One-time provisioning command for offline rerank runtime/eval:
# uv run python scripts/provision_rerank_model.py

# Phase 2 vector-store preset: chroma (default, local) or pinecone (serverless).
# The eval scripts always use local Chroma regardless — only the serving path swaps.
# For the Hugging Face Space demo, set GENACADEMY_VECTORSTORE=pinecone and provide
# PINECONE_API_KEY as a Space secret. Keep 384-d local embeddings unless using a fresh
# matching-dimension Pinecone index.
GENACADEMY_VECTORSTORE=chroma
PINECONE_API_KEY=
GENACADEMY_PINECONE_INDEX=genacademy-rag
GENACADEMY_PINECONE_CLOUD=aws
GENACADEMY_PINECONE_REGION=us-east-1

# Deployment / Hugging Face Space
# Set GENACADEMY_SESSION_SECRET as a Space secret, not a public variable.
# Prefer an absolute path; uncomment only when overriding the app default.
# GENACADEMY_DATA_DIR=/absolute/path/to/data
GENACADEMY_SECURE_COOKIES=false
